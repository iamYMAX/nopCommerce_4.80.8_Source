@model Nop.Web.Models.Common.FooterModel

@using Nop.Core
@using Nop.Core.Domain.Tax

@{
    //Layout = ""; // It's a component, no layout needed here
}

<div class="footer iomnieye-footer"> @* Add a theme-specific class *@
    <div class="footer-upper"> @* This corresponds to the iOmniEYE <section id="contact"> *@
        <div class="container mx-auto text-center"> @* Helper classes for centering, will be styled in CSS *@
            <h2 class="text-3xl font-bold">@T("Footer.FollowUs")</h2> @* Re-using NopC localization *@
            <div class="social-links mt-7"> @* Corresponds to iOmniEYE social-links div *@
                @await Component.InvokeAsync(typeof(SocialButtonsViewComponent))
            </div>
            @* Optionally, add contact details here if they are static or from a new model property *@
        </div>
    </div>

    @* Keep NopCommerce's standard lower footer for copyright, etc. *@
    <div class="footer-lower">
        <div class="footer-info">
            <span class="footer-disclaimer">@T("Content.CopyrightNotice", DateTime.Now.Year, Model.StoreName)</span>
            @if (Model.DisplayTaxShippingInfoFooter)
            {
                var inclTax = await workContext.GetTaxDisplayTypeAsync() == TaxDisplayType.IncludingTax;
                <span class="footer-tax-shipping">
                    @T(inclTax ? "Footer.TaxShipping.InclTax" : "Footer.TaxShipping.ExclTax", Url.RouteTopicUrl("shippinginfo"))
                </span>
            }
        </div>
        @if (!Model.HidePoweredByNopCommerce)
        {
            <div class="footer-powered-by">
                Powered by <a href="@(OfficialSite.Main)" target="_blank" @(Model.IsHomePage ? string.Empty : "rel=nofollow")>nopCommerce</a>
            </div>
        }
        @await Component.InvokeAsync(typeof(StoreThemeSelectorViewComponent)) @* Keep theme selector for testing, can be removed/styled later *@
    </div>
    @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.Footer, additionalData = Model })
</div>

@* Retain existing NopCommerce footer scripts for mobile accordion behavior, if still applicable *@
<script asp-location="Footer">
    $(function() {
        // Mobile footer block collapse (if any blocks are still using .title + .list structure)
        $('.iomnieye-footer .footer-block .title').on('click', function () {
            if (window.innerWidth < 769) {
                $(this).siblings('.list').slideToggle('slow');
            }
        });
        // General block collapse for side columns, if still relevant
        $('.block .title').on('click', function () {
            if (window.innerWidth < 1001) {
                $(this).siblings('.listbox').slideToggle('slow');
            }
        });
    });
</script>
